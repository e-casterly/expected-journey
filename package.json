{
  "name": "expected-journey",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "docker compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "sprites:ofm": "pnpm --filter @tools/ofm-sprites run generate -- --input ../../public/map/sprites/svgs_iconset --output-dir ../../public/map/sprites/old --name ofm",
    "maputnik": "docker run -it --rm -p 8888:8000 ghcr.io/maplibre/maputnik:main",
    "icons:generate": "npx @svgr/cli src/svgs --out-dir src/components/icons --typescript --no-prettier"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@floating-ui/react": "^0.27.19",
