# PostgreSQL connection string
# Matches the default docker-compose.yml settings
DATABASE_URL=postgresql://expected_journey:ej_password@localhost:5432/expected_journey

NODE_ENV=development

# Better Auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional)
# https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email (optional, for magic link / email verification)
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM="Expected Journey <noreply@local.dev>"